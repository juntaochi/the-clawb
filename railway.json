{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "/apps/server/Dockerfile",
    "buildCommand": null,
    "watchPatterns": [
      "/apps/server/**",
      "/packages/shared/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/turbo.json",
      "/tsconfig.base.json",
      "/railway.json"
    ]
  },
  "deploy": {
    "startCommand": null,
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
